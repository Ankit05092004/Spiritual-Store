# =============================================================================
# MahadevAstro — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env or .env.local to git.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE (Neon / Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Get from: https://neon.tech or https://supabase.com → Project Settings → Connection string
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_uGqJ7vLbWUs6@ep-blue-boat-a185z9fh-pooler.ap-southeast-1.aws.neon.tech/Store?sslmode=require&channel_binding=require


# -----------------------------------------------------------------------------
# CLERK AUTHENTICATION
# -----------------------------------------------------------------------------
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZHluYW1pYy1zaGFkLTg5LmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_KvdDfQwozbZ6qpAv2j2uvphSWSm8B7dAAEr6m9ZyZ6

# Clerk redirect routes (keep as-is unless you rename the pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/


# -----------------------------------------------------------------------------
# CASHFREE PAYMENT GATEWAY
# -----------------------------------------------------------------------------
# Get from: https://merchant.cashfree.com → Developers → API Keys
# Set CASHFREE_ENV to "production" in prod, leave as anything else for sandbox
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_ENV=sandbox

# Set to "production" in prod for the client-side SDK mode
NEXT_PUBLIC_CASHFREE_ENV=sandbox


# -----------------------------------------------------------------------------
# RAZORPAY (legacy / backup gateway)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Public key used in client-side Razorpay SDK (same as KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx


# -----------------------------------------------------------------------------
# ARCJET (rate limiting & bot protection)
# -----------------------------------------------------------------------------
# Get from: https://app.arcjet.com → Your Site → API Keys
ARCJET_KEY=ajkey_01kffmm9a5e92b9mvzjcfqs0bb


# -----------------------------------------------------------------------------
# ASTROLOGY API
# -----------------------------------------------------------------------------
# The external astrology chart API key (used in /api/astrology)
# Get from your astrology API provider
ASTROLOGY_API=64Qm01diGg2GgxXCK5FBj7PqSJ8oxgQV2OqeKmIX


# -----------------------------------------------------------------------------
# APP URL
# -----------------------------------------------------------------------------
# Full public URL of your app, no trailing slash.
# Used server-side to build return URLs for Cashfree.
# In production set this to your real domain, e.g. https://mahadevastro.com
# On Vercel, VERCEL_URL is set automatically; NEXT_PUBLIC_APP_URL takes priority.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# GEOCODING API (optional override)
# -----------------------------------------------------------------------------
# Defaults to the free Nominatim endpoint if not set.
# Only needed if you switch to a paid geocoding provider.
# GEOCODING_API=https://nominatim.openstreetmap.org/search


# -----------------------------------------------------------------------------
# SENTRY (error monitoring — optional but recommended in production)
# -----------------------------------------------------------------------------
# Get from: https://sentry.io → Your Project → Settings → SDK Setup
# The DSN is currently hard-coded in sentry.*.config.ts; move it here if needed.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_xxxx   # needed only for source-map uploads on CI


# -----------------------------------------------------------------------------
# SUPABASE (if using Supabase client directly, e.g. storage/realtime)
# -----------------------------------------------------------------------------
# Most DB access goes through Drizzle + DATABASE_URL above.
# Only fill these in if you use the Supabase JS client elsewhere.
# NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
